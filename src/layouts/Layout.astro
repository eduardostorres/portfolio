---
// Inter Variable: una sola fuente con todo el eje de pesos (100–900). El CSS de
// Fontsource declara `font-family: 'Inter Variable'`; precargamos el woff2 para
// adelantar el primer pintado del texto y minimizar el FOUT.
import '@fontsource-variable/inter/wght.css';
import interLatin from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url';
import '../styles/global.css';

import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { serializeForScript } from '../utils/serialize';
import {
  getTranslation,
  routes,
  supportedLangs,
  defaultLang,
  type Lang,
  type RouteKey,
} from '../i18n';

interface Props {
  /** Idioma de esta página. Define el render del servidor y `<html lang>`. */
  lang: Lang;
  /**
   * Página actual (clave estable de `routes`). Se usa para resolver el título,
   * los enlaces alternos por idioma (hreflang) y el estado activo del menú.
   */
  page: RouteKey;
}

const { lang, page } = Astro.props;

const t = getTranslation(lang);

// El título sale del diccionario: la portada usa el título del sitio; el resto,
// el `meta` de su página. El `?? home` es solo un respaldo de tipos.
const docTitle = page === 'home' ? t.meta.title : t.pages[page].meta;

// Descripción específica de cada página; la portada usa la del sitio.
const description =
  page === 'home' ? t.meta.description : t.pages[page].description;

// URLs absolutas para canonical / Open Graph / hreflang, derivadas del mapa de
// rutas para que coincidan con los enlaces alternos.
const siteUrl = Astro.site ?? Astro.url;
const canonical = new URL(routes[page][lang], siteUrl).toString();
const ogImage = new URL('/og.png', siteUrl).toString();
const ogImageAlt =
  lang === 'es'
    ? 'Eduardo Sánchez — Ingeniero backend y full-stack'
    : 'Eduardo Sánchez — Backend & full-stack engineer';

const ogLocale = lang === 'es' ? 'es_MX' : 'en_US';
const ogLocaleAlt = lang === 'es' ? 'en_US' : 'es_MX';

// URLs de esta misma página por idioma, para que el detector de idioma del
// cliente pueda redirigir al equivalente sin recargar de más. Se serializa con
// escape para `<script>` (defensa en profundidad ante `</script>` / inyección).
const altLinks = serializeForScript(routes[page]);

// Datos estructurados (JSON-LD): identidad del autor y del sitio, para que los
// buscadores entiendan quién está detrás del portafolio y lo enlacen entre sí.
const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      '@id': `${siteUrl}#person`,
      name: 'Eduardo Sebastián Sánchez Torres',
      alternateName: 'Eduardo S.',
      url: siteUrl.href,
      jobTitle:
        lang === 'es'
          ? 'Ingeniero backend y full-stack'
          : 'Backend & full-stack engineer',
      sameAs: [
        'https://github.com/eduardostorres',
        'https://www.linkedin.com/in/eduardostorres/',
      ],
    },
    {
      '@type': 'WebSite',
      '@id': `${siteUrl}#website`,
      name: t.meta.title,
      url: siteUrl.href,
      description: t.meta.description,
      inLanguage: lang === 'es' ? 'es-MX' : 'en-US',
      publisher: { '@id': `${siteUrl}#person` },
    },
  ],
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link id="favicon" rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/* Precarga de la fuente: acelera el primer pintado del texto y reduce el FOUT. */}
    <link
      rel="preload"
      href={interLatin}
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link rel="canonical" href={canonical} />
    <meta name="generator" content={Astro.generator} />

    {/* Enlaces alternos por idioma para la misma página. */}
    {
      supportedLangs.map((l) => (
        <link
          rel="alternate"
          hreflang={l}
          href={new URL(routes[page][l], siteUrl).toString()}
        />
      ))
    }
    <link
      rel="alternate"
      hreflang="x-default"
      href={new URL(routes[page][defaultLang], siteUrl).toString()}
    />

    <title>{docTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Eduardo S." />

    <meta
      name="theme-color"
      content="#fafaf8"
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content="#0d0d0d"
      media="(prefers-color-scheme: dark)"
    />

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={docTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlt} />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={docTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    {/* Datos estructurados: Person + WebSite. Se serializa con escape para
        `<script>` para que ningún valor pueda romper el bloque (XSS). */}
    <script
      type="application/ld+json"
      is:inline
      set:html={serializeForScript(structuredData)}
    />

    {/*
      Fija el tema antes del primer pintado para evitar el "flash"
      de color. Script clásico y bloqueante a propósito.
    */}
    <script is:inline>
      (() => {
        const root = document.documentElement;
        // Marca que hay JS: solo entonces el CSS oculta los elementos `data-reveal`
        // para animarlos. Sin JS, el contenido se muestra siempre.
        root.classList.add('js');
        try {
          const stored = localStorage.getItem('theme');
          const theme =
            stored ??
            (matchMedia('(prefers-color-scheme: dark)').matches
              ? 'dark'
              : 'light');
          root.classList.toggle('dark', theme === 'dark');
          root.style.colorScheme = theme;
        } catch (_) {}
      })();
    </script>

    {/* URLs de esta página por idioma, para el detector de abajo. */}
    <script is:inline type="application/json" id="i18n-routes" set:html={altLinks}
    ></script>

    {/*
      Detección de idioma: si el usuario tiene una preferencia (selector) o su
      navegador apunta a otro idioma disponible, redirige a la versión equivalente
      de ESTA página antes de pintar. La preferencia explícita manda sobre el
      navegador; `location.replace` evita ensuciar el historial y bucles.
    */}
    <script is:inline>
      (() => {
        try {
          const node = document.getElementById('i18n-routes');
          if (!node) return;

          const alt = JSON.parse(node.textContent); // { es: '/…', en: '/en/…' }
          const supported = Object.keys(alt);
          const current = document.documentElement.lang;

          const stored = localStorage.getItem('lang');
          const fromBrowser = supported.find((l) =>
            (navigator.language || '').toLowerCase().startsWith(l),
          );
          const preferred =
            (stored && supported.includes(stored) && stored) ||
            fromBrowser ||
            current;

          if (preferred !== current && alt[preferred]) {
            location.replace(alt[preferred]);
          }
        } catch (_) {}
      })();
    </script>
  </head>

  <body class="flex min-h-dvh flex-col antialiased">
    <a
      href="#main"
      class="sr-only rounded-full focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:bg-ink focus:px-4 focus:py-2 focus:text-sm focus:text-bg"
    >
      {lang === 'es' ? 'Saltar al contenido' : 'Skip to content'}
    </a>

    <Header lang={lang} page={page} />

    <main id="main" class="flex-1">
      <slot />
    </main>

    <Footer lang={lang} />

    {/*
      Revelado dirigido por scroll. Observa los elementos `[data-reveal]` y les
      añade `.is-visible` al entrar en viewport (una sola vez). Es la única pieza
      de JS de animación del sitio: ligera, sin dependencias y degradable.
    */}
    <script is:inline>
      (() => {
        const items = document.querySelectorAll('[data-reveal]');
        if (!items.length) return;

        const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduce || !('IntersectionObserver' in window)) {
          items.forEach((el) => el.classList.add('is-visible'));
          return;
        }

        const io = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                obs.unobserve(entry.target);
              }
            });
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.1 },
        );

        items.forEach((el) => io.observe(el));
      })();
    </script>
  </body>
</html>
