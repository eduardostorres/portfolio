---
import type { Lang } from '../../i18n';
import Hero from '../sections/Hero.astro';
import About from '../sections/About.astro';
import Work from '../sections/Work.astro';
import Stack from '../sections/Stack.astro';
import Experience from '../sections/Experience.astro';
import Contact from '../sections/Contact.astro';

/**
 * Portada: experiencia editorial de una sola página. Orquesta, en orden, las
 * secciones Hero → Perfil → Proyectos → Stack → Experiencia → Contacto. Cada
 * sección es autónoma (datos, copy i18n y maquetación propios), por lo que
 * reordenarlas o retirarlas se reduce a tocar este archivo.
 */
interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<Hero lang={lang} />
<About lang={lang} />
<Work lang={lang} />
<Stack lang={lang} />
<Experience lang={lang} />
<Contact lang={lang} />
