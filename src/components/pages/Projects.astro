---
import { getTranslation, type Lang } from '../../i18n';
import { projects, techLabel } from '../../data/projects';
import { serializeForScript } from '../../utils/serialize';
import ProjectFilter from '../ProjectFilter.astro';
import ProjectCard from '../ProjectCard.astro';

/**
 * Página de Proyectos: encabezado, filtro por tecnología y rejilla de tarjetas.
 * El filtro emite `filter:change`; el script de abajo escucha ese evento y
 * muestra u oculta las tarjetas (sin recargar) con una animación de reacomodo.
 */
interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslation(lang);
const content = t.pages.projects;

// Más recientes primero.
const sorted = [...projects].sort((a, b) => b.year - a.year);
const total = sorted.length;
const countWord =
  total === 1 ? t.projectsList.countSingular : t.projectsList.countPlural;

// URL canónica de esta página (origen del sitio + ruta actual).
const pageUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url).href;

const isReal = (url?: string): url is string => Boolean(url) && url !== '#';

// JSON-LD: la página como colección con la lista ordenada de proyectos.
const collectionLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: content.title,
  description: content.description,
  url: pageUrl,
  inLanguage: lang === 'es' ? 'es-MX' : 'en-US',
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: total,
    itemListElement: sorted.map((project, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      item: {
        '@type': 'CreativeWork',
        name: project.title[lang],
        description: project.description[lang],
        keywords: project.tech.map((value) => techLabel(value)).join(', '),
        ...(isReal(project.demo)
          ? { url: project.demo }
          : isReal(project.repo)
            ? { url: project.repo }
            : {}),
      },
    })),
  },
};
---

<section class="flex w-full max-w-3xl flex-col self-start">
  <header class="reveal-fade">
    <h1
      class="text-balance text-3xl font-bold leading-tight tracking-tight text-foreground"
    >
      {content.title}
    </h1>
    <p class="mt-3 max-w-2xl text-pretty text-xs leading-relaxed text-muted">
      {content.intro}
    </p>
  </header>

  {/* Barra de herramientas: filtro + contador de resultados.
      `relative z-20`: la animación `reveal` deja un `transform` que convierte
      esta barra en un stacking context; sin un z-index propio, las tarjetas
      (hermanas posteriores) se pintarían por encima del menú desplegable. */}
  <div
    class="reveal relative z-20 mt-8 flex flex-wrap items-center justify-between gap-3"
    style="animation-delay: 90ms"
  >
    <ProjectFilter lang={lang} />
    <p
      data-projects-count
      data-singular={t.projectsList.countSingular}
      data-plural={t.projectsList.countPlural}
      aria-live="polite"
      class="text-xs tabular-nums text-muted"
    >
      {total}{' '}{countWord}
    </p>
  </div>

  {/* Rejilla de tarjetas */}
  <div
    data-projects-grid
    class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2"
  >
    {
      sorted.map((project, index) => (
        <ProjectCard project={project} index={index} lang={lang} />
      ))
    }
  </div>

  {/* Estado vacío: solo visible si un filtro no deja resultados */}
  <p
    data-projects-empty
    hidden
    class="reveal-fade mt-12 text-center text-xs text-muted"
  >
    {t.projectsList.empty}
  </p>
</section>

{/* Datos estructurados: colección + lista de proyectos. Serializado con escape
    para `<script>` para que ningún título/descripción pueda romper el bloque. */}
<script
  type="application/ld+json"
  is:inline
  set:html={serializeForScript(collectionLd)}
/>

<script>
  // Conecta el filtro con la rejilla. Escucha `filter:change` (emitido por
  // ProjectFilter) y muestra/oculta tarjetas según su `data-tech`.
  const cards = Array.from(
    document.querySelectorAll<HTMLElement>('[data-project]'),
  );
  const countEl = document.querySelector<HTMLElement>('[data-projects-count]');
  const emptyEl = document.querySelector<HTMLElement>('[data-projects-empty]');

  // Reinicia la animación `reveal` en las tarjetas visibles, escalonada, para
  // que la rejilla se reacomode con suavidad tras filtrar.
  const replayReveal = (els: HTMLElement[]): void => {
    els.forEach((el, i) => {
      el.classList.remove('reveal');
      el.style.animationDelay = `${i * 45}ms`;
      void el.offsetWidth; // fuerza el reinicio de la animación
      el.classList.add('reveal');
    });
  };

  const applyFilter = (value: string): void => {
    const shown: HTMLElement[] = [];

    cards.forEach((card) => {
      const techs = (card.dataset.tech ?? '').split(' ');
      const match = value === 'all' || techs.includes(value);
      // Estilo inline: gana sobre la utilidad `flex` de la tarjeta.
      card.style.display = match ? '' : 'none';
      if (match) shown.push(card);
    });

    if (countEl) {
      const word =
        shown.length === 1 ? countEl.dataset.singular : countEl.dataset.plural;
      countEl.textContent = `${shown.length} ${word}`;
    }
    if (emptyEl) emptyEl.hidden = shown.length !== 0;

    replayReveal(shown);
  };

  document.addEventListener('filter:change', (event) => {
    const detail = (event as CustomEvent<{ value: string }>).detail;
    applyFilter(detail?.value ?? 'all');
  });
</script>
