---
import { getTranslation, type Lang } from '../i18n';
import { technologies } from '../data/projects';

interface Props {
  /** Idioma activo: define la etiqueta accesible y la opción «Todas». */
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslation(lang);

const allOption = { value: 'all', label: t.projectsFilter.all };
// «Todas» queda primera y es la seleccionada por defecto. El resto sale del
// registro compartido (`data/projects`) para no duplicar la lista.
const options = [allOption, ...technologies];
---

<div id="project-filter" class="relative inline-block text-left">
  {/* Disparador: ícono de filtro + tecnología activa + chevron. */}
  <button
    type="button"
    data-filter-trigger
    aria-haspopup="listbox"
    aria-expanded="false"
    aria-controls="project-filter-menu"
    aria-label={t.projectsFilter.label}
    class="group inline-flex items-center gap-2.5 rounded-full border border-border bg-background px-4 py-2.5 text-xs text-foreground duration-200 hover:border-foreground/20 hover:bg-foreground/[0.04] focus-visible:border-foreground/30"
  >
    <svg
      class="h-4 w-4 text-muted duration-200 group-hover:text-foreground"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.75"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon>
    </svg>

    <span data-filter-current class="font-bold">{allOption.label}</span>

    <svg
      class="h-4 w-4 text-muted transition-transform duration-200 group-aria-[expanded=true]:rotate-180"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.75"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="m6 9 6 6 6-6"></path>
    </svg>
  </button>

  {/* Menú flotante. Cerrado: inerte + invisible y desplazado; abrir solo cambia
      atributos/estilos (sin display/visibility), para que la animación de cierre
      también se reproduzca. */}
  <div
    id="project-filter-menu"
    data-filter-menu
    role="listbox"
    tabindex="-1"
    aria-label={t.projectsFilter.label}
    inert
    class="pointer-events-none absolute left-0 top-[calc(100%+0.625rem)] z-30 max-h-[60vh] w-64 origin-top -translate-y-2 scale-95 overflow-y-auto rounded-2xl border border-border bg-background p-1.5 opacity-0 shadow-xl shadow-black/5 transition duration-200 ease-out data-[open]:pointer-events-auto data-[open]:translate-y-0 data-[open]:scale-100 data-[open]:opacity-100 dark:shadow-black/40"
  >
    {
      options.map((opt, index) => (
        <button
          type="button"
          role="option"
          data-value={opt.value}
          data-label={opt.label}
          aria-selected={index === 0 ? 'true' : 'false'}
          class="group flex w-full items-center justify-between gap-3 rounded-xl px-3.5 py-2.5 text-left text-xs text-muted duration-200 hover:bg-foreground/[0.05] hover:text-foreground focus:bg-foreground/[0.05] focus:text-foreground focus:outline-none aria-[selected=true]:font-bold aria-[selected=true]:text-foreground"
        >
          <span>{opt.label}</span>
          <svg
            class="h-4 w-4 shrink-0 text-accent opacity-0 transition-opacity duration-200 group-aria-[selected=true]:opacity-100"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M20 6 9 17l-5-5" />
          </svg>
        </button>
      ))
    }
  </div>
</div>

<script>
  // UI del filtro: abre/cierra el menú y resalta la opción activa. NO filtra
  // nada todavía; al elegir una tecnología emite `filter:change` con su valor,
  // listo para que la lógica de filtrado se conecte más adelante.
  const root = document.getElementById('project-filter');
  const trigger = root?.querySelector<HTMLButtonElement>('[data-filter-trigger]');
  const menu = root?.querySelector<HTMLElement>('[data-filter-menu]');
  const current = root?.querySelector<HTMLElement>('[data-filter-current]');
  const options = Array.from(
    root?.querySelectorAll<HTMLButtonElement>('[role="option"]') ?? [],
  );

  if (root && trigger && menu) {
    const isOpen = (): boolean =>
      trigger.getAttribute('aria-expanded') === 'true';

    const setOpen = (open: boolean): void => {
      trigger.setAttribute('aria-expanded', String(open));
      menu.toggleAttribute('data-open', open);
      menu.toggleAttribute('inert', !open);
    };

    const close = (focusTrigger = false): void => {
      setOpen(false);
      if (focusTrigger) trigger.focus();
    };

    // Foco circular entre opciones (roving focus).
    const focusOption = (index: number): void => {
      const count = options.length;
      if (count) options[((index % count) + count) % count]?.focus();
    };

    const selectedIndex = (): number =>
      options.findIndex((o) => o.getAttribute('aria-selected') === 'true');

    const open = (focusSelected = false): void => {
      setOpen(true);
      if (focusSelected) focusOption(Math.max(selectedIndex(), 0));
    };

    const select = (option: HTMLButtonElement): void => {
      options.forEach((o) =>
        o.setAttribute('aria-selected', String(o === option)),
      );
      if (current) current.textContent = option.dataset.label ?? '';
      root.dispatchEvent(
        new CustomEvent('filter:change', {
          bubbles: true,
          detail: { value: option.dataset.value ?? 'all' },
        }),
      );
    };

    trigger.addEventListener('click', () => (isOpen() ? close() : open()));

    trigger.addEventListener('keydown', (event) => {
      if (event.key === 'ArrowDown' || event.key === 'ArrowUp') {
        event.preventDefault();
        open(true);
      }
    });

    options.forEach((option, index) => {
      option.addEventListener('click', () => {
        select(option);
        close(true);
      });

      option.addEventListener('keydown', (event) => {
        switch (event.key) {
          case 'ArrowDown':
            event.preventDefault();
            focusOption(index + 1);
            break;
          case 'ArrowUp':
            event.preventDefault();
            focusOption(index - 1);
            break;
          case 'Home':
            event.preventDefault();
            focusOption(0);
            break;
          case 'End':
            event.preventDefault();
            focusOption(options.length - 1);
            break;
          case 'Tab':
            close();
            break;
        }
      });
    });

    // Cierra al hacer clic fuera o con Escape; devuelve el foco al disparador.
    document.addEventListener('click', (event) => {
      if (isOpen() && !root.contains(event.target as Node)) close();
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && isOpen()) close(true);
    });
  }
</script>
