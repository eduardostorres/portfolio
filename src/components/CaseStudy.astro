---
import { techLabel, type Project } from '../data/projects';
import { getTranslation, type Lang } from '../i18n';

/**
 * Caso de estudio de un proyecto: un visual grande (captura real si se aporta
 * `image`, o un panel tipográfico elegante si no), y una columna editorial con
 * problema, solución, resultado, stack y enlaces. La disposición alterna el lado
 * del visual según la paridad del índice para dar ritmo a la sección.
 */
interface Props {
  project: Project;
  index: number;
  lang: Lang;
}

const { project, index, lang } = Astro.props;
const t = getTranslation(lang);

const number = String(index + 1).padStart(2, '0');

const isReal = (url?: string): url is string => Boolean(url) && url !== '#';
const repo = isReal(project.repo) ? project.repo : undefined;
const demo = isReal(project.demo) ? project.demo : undefined;

const title = project.title[lang];
const letter = title.charAt(0).toUpperCase();

// Etiqueta del visual: el dominio de la demo, o el estado «en desarrollo».
const domain = demo ? new URL(demo).hostname.replace(/^www\./, '') : undefined;
const visualLabel = domain ?? (project.inProgress ? t.work.inProgress : '');

// El visual ocupa la derecha en impares y la izquierda en pares (md+).
const visualLast = index % 2 === 0;

// Bloques del caso de estudio que existan.
const facts = [
  { label: t.work.problem, value: project.problem?.[lang], accent: false },
  { label: t.work.solution, value: project.solution?.[lang], accent: false },
  { label: t.work.result, value: project.result?.[lang], accent: true },
].filter((f) => Boolean(f.value));
---

<article
  data-reveal
  class="grid items-center gap-8 md:grid-cols-12 md:gap-12 lg:gap-16"
>
  {/* ── Visual ─────────────────────────────────────────────────── */}
  <div class={`md:col-span-7 ${visualLast ? 'md:order-2' : 'md:order-1'}`}>
    <a
      href={demo ?? repo ?? undefined}
      target={demo || repo ? '_blank' : undefined}
      rel={demo || repo ? 'noopener noreferrer' : undefined}
      aria-label={demo || repo ? `${title} — ${domain ?? t.work.code}` : undefined}
      class:list={[
        'group relative block aspect-[16/10] overflow-hidden rounded-2xl border border-line bg-surface transition-[border-color,transform] duration-300',
        (demo || repo) && 'hover:-translate-y-1 hover:border-line-strong',
        !(demo || repo) && 'pointer-events-none',
      ]}
    >
      {
        project.image ? (
          <img
            src={project.image}
            alt={`${title} — ${project.description[lang]}`}
            loading="lazy"
            decoding="async"
            class="h-full w-full object-cover"
          />
        ) : (
          <span
            aria-hidden="true"
            class="flex h-full w-full items-center justify-center"
          >
            <span class="select-none text-[clamp(4rem,13vw,9rem)] font-semibold leading-none tracking-tight text-ink/[0.07] transition-colors duration-300 group-hover:text-accent/15">
              {letter}
            </span>
          </span>
        )
      }
      {
        visualLabel && (
          <span class="absolute bottom-4 left-5 text-xs text-faint">
            {visualLabel}
          </span>
        )
      }
    </a>
  </div>

  {/* ── Contenido ──────────────────────────────────────────────── */}
  <div class={`md:col-span-5 ${visualLast ? 'md:order-1' : 'md:order-2'}`}>
    <div class="flex items-center gap-3 text-[0.7rem] font-medium uppercase tracking-[0.18em] text-faint">
      <span class="tnum text-accent">{number}</span>
      <span aria-hidden="true" class="h-px w-6 bg-line-strong"></span>
      <span class="tnum">{project.year}</span>
    </div>

    <h3 class="mt-4 text-2xl font-semibold tracking-tight text-ink sm:text-3xl">
      {title}
    </h3>

    <p class="mt-3 text-pretty text-base leading-relaxed text-muted">
      {project.description[lang]}
    </p>

    {
      facts.length > 0 && (
        <dl class="mt-7 space-y-5 border-t border-line pt-7">
          {facts.map((fact) => (
            <div class="grid grid-cols-[5.5rem_1fr] gap-x-4">
              <dt class="pt-0.5 text-[0.7rem] uppercase tracking-[0.16em] text-faint">
                {fact.label}
              </dt>
              <dd
                class:list={[
                  'text-sm leading-relaxed',
                  fact.accent ? 'text-ink' : 'text-muted',
                ]}
              >
                {fact.value}
              </dd>
            </div>
          ))}
        </dl>
      )
    }

    {/* Stack */}
    <ul class="mt-7 flex flex-wrap items-center gap-x-2.5 gap-y-1.5 text-xs text-muted">
      {
        project.tech.map((value, i) => (
          <li class="flex items-center gap-2.5">
            {i > 0 && (
              <span aria-hidden="true" class="text-faint">
                ·
              </span>
            )}
            {techLabel(value)}
          </li>
        ))
      }
    </ul>

    {/* Enlaces */}
    {
      (demo || repo) && (
        <div class="mt-7 flex flex-wrap items-center gap-x-6 gap-y-3">
          {demo && (
            <a
              href={demo}
              target="_blank"
              rel="noopener noreferrer"
              class="group inline-flex items-center gap-2 text-sm font-medium text-ink duration-200 hover:text-accent focus-visible:text-accent"
            >
              {t.work.demo}
              <svg
                class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.7"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M7 17 17 7M8 7h9v9" />
              </svg>
            </a>
          )}
          {repo && (
            <a
              href={repo}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm text-muted duration-200 hover:text-ink focus-visible:text-ink"
            >
              <svg
                class="h-4 w-4"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
              </svg>
              {t.work.code}
            </a>
          )}
        </div>
      )
    }
  </div>
</article>
