---
import {
  languages,
  supportedLangs,
  routes,
  getTranslation,
  type Lang,
  type RouteKey,
} from '../i18n';

/**
 * Selector de idioma minimalista (ES · EN). Cada opción es un enlace real a la
 * MISMA página en el otro idioma (bueno para SEO y para navegación sin JS). Al
 * hacer clic se guarda la elección en `localStorage` para que el detector del
 * Layout la respete después; esa preferencia explícita prevalece sobre el
 * idioma del navegador.
 */
interface Props {
  lang: Lang;
  page: RouteKey;
}

const { lang, page } = Astro.props;
const t = getTranslation(lang);
---

<div
  role="group"
  aria-label={t.a11y.language}
  class="inline-flex items-center gap-1.5 text-xs tracking-wide"
>
  {
    supportedLangs.map((l, i) => (
      <>
        {i > 0 && (
          <span aria-hidden="true" class="text-faint">
            /
          </span>
        )}
        <a
          href={routes[page][l]}
          hreflang={l}
          title={languages[l]}
          data-lang-switch={l}
          aria-current={l === lang ? 'true' : 'false'}
          class="uppercase text-muted duration-200 hover:text-ink focus-visible:text-ink aria-[current=true]:font-semibold aria-[current=true]:text-ink"
        >
          {l}
        </a>
      </>
    ))
  }
</div>

<script>
  // Guarda la elección explícita de idioma antes de navegar: esta preferencia
  // tiene prioridad sobre el idioma del navegador en el detector del Layout.
  document
    .querySelectorAll<HTMLAnchorElement>('[data-lang-switch]')
    .forEach((el) => {
      el.addEventListener('click', () => {
        const lang = el.dataset.langSwitch;
        if (lang) localStorage.setItem('lang', lang);
      });
    });
</script>
