---
import {
  languages,
  supportedLangs,
  routes,
  getTranslation,
  type Lang,
  type RouteKey,
} from '../i18n';

interface Props {
  /** Idioma activo de la página. */
  lang: Lang;
  /** Página actual: se usa para enlazar a su equivalente en cada idioma. */
  page: RouteKey;
}

const { lang, page } = Astro.props;
const t = getTranslation(lang);
---

{/* Selector segmentado: cada opción enlaza a esta misma página en su idioma. */}
<div
  role="group"
  aria-label={t.a11y.language}
  class="inline-flex items-center rounded-full border border-border p-0.5"
>
  {
    supportedLangs.map((l) => (
      <a
        href={routes[page][l]}
        hreflang={l}
        title={languages[l]}
        data-lang-switch={l}
        aria-current={l === lang ? 'true' : 'false'}
        class="rounded-full px-2.5 py-1 text-xs font-bold uppercase tracking-wider text-muted duration-200 hover:text-foreground focus-visible:text-foreground aria-[current=true]:bg-foreground aria-[current=true]:text-background"
      >
        {l}
      </a>
    ))
  }
</div>

<script>
  // Guarda la elección explícita de idioma antes de navegar: esta preferencia
  // tiene prioridad sobre el idioma del navegador en el detector del Layout.
  document.querySelectorAll<HTMLAnchorElement>('[data-lang-switch]').forEach(
    (el) => {
      el.addEventListener('click', () => {
        const lang = el.dataset.langSwitch;
        if (lang) localStorage.setItem('lang', lang);
      });
    },
  );
</script>
