---
import { languages, supportedLangs, getTranslation, defaultLang } from '../i18n';

const t = getTranslation(defaultLang);
---

{/* Selector segmentado. La lógica vive centralizada en Layout.astro (i18n). */}
<div
  role="group"
  aria-label={t.a11y.language}
  data-i18n-aria="a11y.language"
  class="inline-flex items-center rounded-full border border-border p-0.5"
>
  {
    supportedLangs.map((lang) => (
      <button
        type="button"
        data-lang-option={lang}
        title={languages[lang]}
        aria-pressed={lang === defaultLang ? 'true' : 'false'}
        class="rounded-full px-2.5 py-1 text-xs font-bold uppercase tracking-wider text-muted duration-200 hover:text-foreground focus-visible:text-foreground aria-[pressed=true]:bg-foreground aria-[pressed=true]:text-background"
      >
        {lang}
      </button>
    ))
  }
</div>
