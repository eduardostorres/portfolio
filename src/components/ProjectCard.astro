---
import { techLabel, type Project } from '../data/projects';
import { getTranslation, type Lang } from '../i18n';

/**
 * Tarjeta de un proyecto: número de orden, año, título, descripción, etiquetas
 * de tecnología y, si existen, enlaces a repositorio y demo. El `data-tech` que
 * se emite en el artículo es lo que usa el filtro de la página para mostrar u
 * ocultar la tarjeta. Los enlaces marcados con `#` (placeholder) se omiten para
 * no abrir pestañas vacías.
 */
interface Props {
  project: Project;
  /** Posición en la lista: número visible y escalonado de la animación. */
  index: number;
  lang: Lang;
}

const { project, index, lang } = Astro.props;
const t = getTranslation(lang);

const number = String(index + 1).padStart(2, '0');

// Solo tratamos como enlace real lo que no sea el marcador `#`; así las
// tarjetas de ejemplo no abren una pestaña vacía al hacer clic.
const isReal = (url?: string): url is string => Boolean(url) && url !== '#';
const repo = isReal(project.repo) ? project.repo : undefined;
const demo = isReal(project.demo) ? project.demo : undefined;
const hasLinks = Boolean(repo || demo);

const title = project.title[lang];
---

<article
  data-project
  data-tech={project.tech.join(' ')}
  class="group reveal flex flex-col rounded-2xl border border-border bg-background p-5 transition-[transform,border-color,background-color,box-shadow] duration-300 ease-out hover:-translate-y-1 hover:border-foreground/20 hover:bg-foreground/[0.02] hover:shadow-xl hover:shadow-black/5 sm:p-6 dark:hover:shadow-black/40"
  style={`animation-delay: ${120 + index * 70}ms`}
>
  {/* Cabecera: número de orden + año */}
  <div class="flex items-start justify-between">
    <span
      class="text-xs font-bold tabular-nums text-muted transition-colors duration-300 group-hover:text-accent"
    >
      {number}
    </span>
    <span class="text-xs tabular-nums text-muted">{project.year}</span>
  </div>

  <h2
    class="mt-4 text-base font-bold leading-snug tracking-tight text-foreground"
  >
    {title}
  </h2>

  <p class="mt-2 grow text-xs leading-relaxed text-pretty text-muted">
    {project.description[lang]}
  </p>

  {/* Tecnologías */}
  <ul class="mt-4 flex flex-wrap gap-1.5">
    {
      project.tech.map((value) => (
        <li class="rounded-full border border-border px-2.5 py-1 text-[0.7rem] leading-none text-muted">
          {techLabel(value)}
        </li>
      ))
    }
  </ul>

  {/* Enlaces */}
  {
    hasLinks && (
      <div class="mt-5 flex items-center gap-4 border-t border-border pt-4">
        {repo && (
          <a
            href={repo}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-xs text-muted duration-200 hover:text-foreground focus-visible:text-foreground"
          >
            <svg
              class="h-[15px] w-[15px]"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" />
            </svg>
            {t.projectsList.code}
          </a>
        )}
        {demo && (
          <a
            href={demo}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-xs text-muted duration-200 hover:text-foreground focus-visible:text-foreground"
          >
            <svg
              class="h-[15px] w-[15px]"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M15 3h6v6" />
              <path d="M10 14 21 3" />
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h6" />
            </svg>
            {t.projectsList.demo}
          </a>
        )}
      </div>
    )
  }
</article>
