---
import { getTranslation, routes, type Lang, type RouteKey } from '../i18n';
import LanguageSwitcher from './LanguageSwitcher.astro';
import ThemeToggle from './ThemeToggle.astro';

/**
 * Cabecera fija del sitio: monograma, navegación por anclas a las secciones de
 * la portada, selector de idioma y conmutador de tema. Los enlaces apuntan a
 * `home#sección`, por lo que funcionan desde cualquier página (incluido el
 * ensayo): navegan a la portada y se desplazan a la sección. Un observador
 * marca la sección activa (scroll-spy); el menú móvil vive en el `<script>`.
 */
interface Props {
  lang: Lang;
  page: RouteKey;
}

const { lang } = Astro.props;
const t = getTranslation(lang);

const home = routes.home[lang];

// Anclas a las secciones de la portada. El orden define el orden visual.
const sections = ['about', 'work', 'stack', 'experience', 'contact'] as const;
const links = sections.map((key) => ({
  key,
  href: `${home}#${key}`,
  label: t.nav[key],
}));
---

<header
  id="site-header"
  class="sticky top-0 z-50 border-b border-transparent bg-bg/0 backdrop-blur-0 transition-[background-color,border-color,backdrop-filter] duration-300 data-[scrolled]:border-line data-[scrolled]:bg-bg/75 data-[scrolled]:backdrop-blur-xl"
>
  <div
    class="mx-auto flex h-16 w-full max-w-6xl items-center justify-between gap-4 px-6 sm:px-8"
  >
    <a
      href={home}
      aria-label={t.a11y.home}
      class="group inline-flex items-baseline text-[0.95rem] font-semibold tracking-tight text-ink duration-200 hover:opacity-70 focus-visible:opacity-70"
    >
      Eduardo Sánchez<span class="text-accent" aria-hidden="true">.</span>
    </a>

    {/* Navegación de escritorio */}
    <nav aria-label={t.a11y.nav} class="hidden md:block">
      <ul class="flex items-center gap-7">
        {
          links.map((link) => (
            <li>
              <a
                href={link.href}
                data-nav={link.key}
                class="group relative text-[0.8rem] text-muted duration-200 hover:text-ink focus-visible:text-ink aria-[current=true]:text-ink"
              >
                {link.label}
                <span
                  aria-hidden="true"
                  class="absolute -bottom-1.5 left-0 h-px w-full origin-left scale-x-0 bg-accent transition-transform duration-200 group-hover:scale-x-100 group-aria-[current=true]:scale-x-100"
                />
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="flex items-center gap-3 sm:gap-4">
      <LanguageSwitcher lang={lang} page={Astro.props.page} />
      <span aria-hidden="true" class="hidden h-4 w-px bg-line sm:block"></span>
      <ThemeToggle lang={lang} />

      {/* Disparador del menú móvil */}
      <button
        type="button"
        id="nav-toggle"
        aria-label={t.a11y.menu}
        aria-expanded="false"
        aria-controls="mobile-nav"
        class="group -mr-1.5 inline-flex h-9 w-9 items-center justify-center rounded-full text-muted duration-200 hover:bg-ink/[0.05] hover:text-ink md:hidden"
      >
        <svg
          class="h-[18px] w-[18px] group-aria-[expanded=true]:hidden"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <path d="M3 7h18M3 17h18"></path>
        </svg>
        <svg
          class="hidden h-[18px] w-[18px] group-aria-[expanded=true]:block"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <path d="M18 6 6 18M6 6l12 12"></path>
        </svg>
      </button>
    </div>
  </div>

  {/* Navegación móvil */}
  <nav
    id="mobile-nav"
    aria-label={t.a11y.nav}
    hidden
    class="border-t border-line bg-bg/95 backdrop-blur-xl md:hidden"
  >
    <ul class="mx-auto flex w-full max-w-6xl flex-col px-4 py-3 sm:px-6">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              data-mobile-link
              class="block rounded-lg px-3 py-3 text-base text-muted duration-200 hover:bg-ink/[0.04] hover:text-ink"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<script>
  // ── Estado de scroll: hairline + backdrop cuando la página no está arriba.
  const header = document.getElementById('site-header');
  const setScrolled = (): void => {
    if (header) header.toggleAttribute('data-scrolled', window.scrollY > 8);
  };
  setScrolled();
  window.addEventListener('scroll', setScrolled, { passive: true });

  // ── Menú móvil. El estado vive en `aria-expanded` (única fuente de verdad).
  const toggle = document.getElementById('nav-toggle');
  const panel = document.getElementById('mobile-nav');

  const setOpen = (open: boolean): void => {
    toggle?.setAttribute('aria-expanded', String(open));
    if (panel) panel.hidden = !open;
  };

  toggle?.addEventListener('click', () => {
    setOpen(toggle.getAttribute('aria-expanded') !== 'true');
  });

  // Cierra al elegir un enlace o con Escape.
  panel
    ?.querySelectorAll('[data-mobile-link]')
    .forEach((link) => link.addEventListener('click', () => setOpen(false)));

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && toggle?.getAttribute('aria-expanded') === 'true') {
      setOpen(false);
      toggle.focus();
    }
  });

  // ── Scroll-spy: marca el enlace de la sección visible (solo en la portada,
  // donde existen las secciones con esos `id`).
  const navLinks = Array.from(
    document.querySelectorAll<HTMLAnchorElement>('[data-nav]'),
  );
  const sections = navLinks
    .map((link) => document.getElementById(link.dataset.nav ?? ''))
    .filter((el): el is HTMLElement => el !== null);

  if (sections.length) {
    const spy = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const id = entry.target.id;
          navLinks.forEach((link) =>
            link.setAttribute('aria-current', String(link.dataset.nav === id)),
          );
        });
      },
      { rootMargin: '-45% 0px -50% 0px' },
    );
    sections.forEach((section) => spy.observe(section));
  }
</script>
