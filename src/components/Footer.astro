---
import { getTranslation, type Lang } from '../i18n';

/**
 * Pie de página: aviso de copyright con el año actual y la nota de derechos
 * (traducida). El año se calcula en tiempo de build, por lo que se mantiene al
 * día con cada despliegue sin necesidad de tocar el código.
 */
interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslation(lang);
// Año actual, resuelto en el build (sitio estático): evita un año «congelado».
const year = new Date().getFullYear();
const name = 'Eduardo S.';
---

<footer class="w-full">
  <div class="mx-auto w-full max-w-5xl px-6 py-8 sm:px-8">
    <p class="reveal-fade text-center text-xs leading-relaxed text-muted">
      <span>&copy; {year} {name}</span>
      <span aria-hidden="true" class="mx-1.5">&middot;</span>
      <span>{t.footer.rights}</span>
    </p>
  </div>
</footer>
