---
import { getTranslation, type Lang } from '../../i18n';
import { profiles } from '../../data/profiles';
import SectionHeading from '../SectionHeading.astro';

/**
 * Contacto. Privacy by Design: el sitio no expone correo, teléfono ni datos
 * personales. La única vía de contacto es LinkedIn, mediante un botón discreto
 * que abre el perfil en una pestaña nueva.
 */
interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslation(lang);
const { linkedin } = profiles;
---

<section id="contact" class="scroll-mt-24 border-t border-line">
  <div class="mx-auto w-full max-w-6xl px-6 py-section sm:px-8">
    <div class="max-w-3xl">
      <SectionHeading
        index={5}
        eyebrow={t.contact.eyebrow}
        title={t.contact.title}
      />

      <p
        data-reveal
        data-reveal-delay="1"
        class="mt-6 max-w-xl text-pretty text-lg leading-relaxed text-muted"
      >
        {t.contact.lead}
      </p>

      <a
        data-reveal
        data-reveal-delay="2"
        href={linkedin.href}
        target="_blank"
        rel="noopener noreferrer"
        class="group mt-10 inline-flex items-center gap-3 rounded-full border border-line-strong px-6 py-3.5 text-sm font-medium text-ink duration-200 hover:border-ink hover:bg-ink hover:text-bg focus-visible:border-ink focus-visible:bg-ink focus-visible:text-bg"
      >
        <svg
          class="h-[18px] w-[18px]"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path d={linkedin.path} />
        </svg>
        {t.contact.cta}
        <svg
          class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.7"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M7 17 17 7M8 7h9v9"></path>
        </svg>
      </a>
    </div>
  </div>
</section>
